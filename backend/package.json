{
  "name": "@public-resource-map/backend",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "db:migrate": "tsx src/db/migrate.ts",
    "db:seed": "tsx src/db/seed.ts",
    "test": "vitest run --root .. --project backend"
  },
  "dependencies": {
    "@fastify/cookie": "11.0.2",
    "@fastify/cors": "11.2.0",
    "@public-resource-map/shared": "*",
    "argon2": "0.44.0",
    "better-sqlite3": "12.11.1",
    "drizzle-orm": "0.45.2",
    "fastify": "5.8.5",
    "zod": "3.25.76"
  },
  "devDependencies": {
    "@types/better-sqlite3": "7.6.13",
    "@types/node": "26.0.1",
    "drizzle-kit": "0.31.10",
    "tsx": "4.22.4",
    "typescript": "5.9.3"
  }
}
